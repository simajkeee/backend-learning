{% extends "base.html.twig" %}


{% block body %}
    <div>
        {% for product in products %}
            <div>
                <h3>
                    <a href="{{ path('app.product', { slug: product.slug }) }}">{{ product.name }}</a>
                </h3>
                <p>{{ product.description }}</p>

                <span>{{ product.price }}</span>
            </div>
        {% endfor %}
    </div>
{% endblock %}